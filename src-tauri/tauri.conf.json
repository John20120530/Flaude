{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flaude",
  "version": "0.1.53",
  "identifier": "com.flaude.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flaude",
        "width": 1280,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "category": "DeveloperTool",
    "shortDescription": "Claude-like client for Chinese open-source LLMs",
    "longDescription": "Flaude is a desktop client that routes requests to Chinese open-source models (DeepSeek, Qwen, GLM, Kimi, MiniMax) with two work modes: Chat and Code.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/John20120530/Flaude/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDMEI1RjRCODkyQUZGQzgKUldUSS95cUpTMThMTEg3b2x5NzQzekhySzh6aHF4ZE5IU3lneDAxdkVoRVpsVVkrenBhbVpKOHUK"
    }
  }
}
