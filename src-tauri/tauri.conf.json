{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flaude",
  "version": "0.1.0",
  "identifier": "com.flaude.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Flaude",
        "width": 1280,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Claude-like client for Chinese open-source LLMs",
    "longDescription": "Flaude is a desktop client that routes requests to Chinese open-source models (DeepSeek, Qwen, GLM, Kimi, MiniMax) with two work modes: Chat and Code.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
